# Google Sheets API — Service Account credentials
# See README.md "Google Sheets Setup" for how to obtain these
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END PRIVATE KEY-----\n"

# Google Spreadsheet
# The ID is the long string in the spreadsheet URL between /d/ and /edit
# NOTE: No sheet name variable. The app discovers monthly tabs (YYYY-MM format) automatically.
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Authentication
# Shared passcode for app access (keep it simple — e.g., a 4-6 digit PIN)
AUTH_PASSCODE=123456

# Session
# Random string, minimum 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-32-char-string
